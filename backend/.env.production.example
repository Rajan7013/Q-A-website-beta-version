# Production Environment Variables for Render Deployment

# Required - Gemini AI API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Server Configuration
PORT=5000
NODE_ENV=production

# CORS Configuration - Add your Vercel frontend URL
FRONTEND_URL=https://your-app-name.vercel.app
CORS_ORIGIN=https://your-app-name.vercel.app

# Optional - Cloudflare R2 Storage (for file uploads)
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=ai-doc-analyzer
R2_PUBLIC_URL=https://your-bucket.r2.dev

# Security (optional - defaults are secure)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
